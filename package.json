{
	"name": "sslko",
	"version": "2.0.12",
	"description": "A simple tool to check SSL/TLS certificate information for a given domain.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OzzyCzech/sslko.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"author": "Roman Ožana <roman@ozana.cz>",
	"keywords": [
		"ssl",
		"ssl-check",
		"ssl-certificate",
		"ssl-tls",
		"tls",
		"certificate",
		"domain",
		"check",
		"nodejs"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"homepage": "https://ozzyczech.github.io/sslko/",
	"type": "module",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --build tsconfig.build.json --clean && tsc -p tsconfig.build.json",
		"release": "np",
		"prepare": "bun run build",
		"test": "tsc --noEmit && bun test",
		"format": "biome check --write .",
		"format:check": "biome check .",
		"docs": "typedoc"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@ozzyczech/tsconfig": "^2.1.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.4",
		"np": "^11.2.1",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3"
	},
	"resolutions": {
		"js-yaml": "^4.1.1",
		"lodash": "^4.18.1",
		"picomatch": "^4.0.4",
		"tmp": "^0.2.5"
	}
}
